<?xml version="1.0"?>
<ruleset name="SortedLinkedList">
    <description>Project coding standard (PHPCS).</description>

    <!-- What to scan -->
    <file>src</file>
    <file>tests</file>
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>build/*</exclude-pattern>

    <!-- Keep CI output readable -->
    <arg value="sp"/>
    <arg name="colors"/>

    <!-- Base standard -->
    <rule ref="PSR12"/>
</ruleset>
